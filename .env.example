APP_NAME="Meet LADETEC"
# Producao: APP_ENV=production e APP_DEBUG=false (nunca exponha debug em producao).
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Producao: use a URL real com https, ex.: APP_URL=https://seu-dominio
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# Janela de expediente (HH:MM) para validacao de reservas e tela de disponibilidade.
RESERVATION_OPENING_TIME=08:00
RESERVATION_CLOSING_TIME=18:00

ALLOW_PUBLIC_REGISTRATION=false
# OBRIGATORIO: senha inicial dos usuarios semeados (admin/secretaria).
# Defina uma senha forte; sem valor o seeder falha de proposito. Troque apos o 1o acesso.
DEFAULT_USER_PASSWORD=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Producao (HTTPS): SESSION_SECURE_COOKIE=true para o cookie so trafegar sob TLS.
SESSION_SECURE_COOKIE=false
# Producao: pode ativar SESSION_ENCRYPT=true para cifrar a sessao em repouso.
SESSION_ENCRYPT=false
# SESSION_SAME_SITE ja usa "lax" e SESSION_HTTP_ONLY=true por padrao (config/session.php).
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EVOLUTION_WHATSAPP_ENABLED=false
EVOLUTION_WHATSAPP_QUEUE=true
EVOLUTION_WHATSAPP_BASE_URL=
EVOLUTION_WHATSAPP_INSTANCE=
EVOLUTION_WHATSAPP_API_KEY=
EVOLUTION_WHATSAPP_TIMEOUT=10
